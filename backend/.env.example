APP_NAME=PRISM Backend
APP_ENV=development
DATABASE_URL=sqlite:///./prism.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
GITHUB_TOKEN=
HUGGINGFACE_TOKEN=
NEWS_RSS_FEEDS=https://www.technologyreview.com/feed/,https://venturebeat.com/category/ai/feed/
ENGINEERING_BLOG_RSS_FEEDS=https://netflixtechblog.com/feed/,https://engineering.fb.com/feed/,https://aws.amazon.com/blogs/machine-learning/feed/
PAPERS_WITH_CODE_API_URL=https://paperswithcode.com/api/v1/papers/
CROSSREF_MAILTO=
ENABLE_LLM=false
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
ENABLE_OPENCLAW=false
OPENCLAW_URL=http://localhost:9000
OPENCLAW_TIMEOUT_SECONDS=10
OPENCLAW_CREDENTIALS_PATH=creds.enc
OPENCLAW_CREDENTIALS_KEY_PATH=creds.key
CHROMA_PERSIST_PATH=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
ENABLE_NEO4J=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
ENABLE_PERSONA=true
ENABLE_SCHEDULER=false
PRISM_HEARTBEAT_HOURS=6
PRISM_AGENT_QUERY=multimodal agents
PRISM_AGENT_LIMIT_PER_SOURCE=5
PRISM_AGENT_INCLUDE_DEMO=true
PRISM_SOUL_PROFILE_PATH=app/agent/soul_profile.yaml
